   3          
   4          void fan_ctl_config(void)
   5          {
   6   1          // 初始化控制风扇开关的引脚：
   7   1          P1_MD0 &= ~(GPIO_P12_MODE_SEL(0x3));
   8   1          P1_MD0 |= (GPIO_P12_MODE_SEL(0x1)); // 输出模式
   9   1          FOUT_S12 = GPIO_FOUT_AF_FUNC;       // 选择AF功能输出
  10   1      
  11   1          P12 = 0; // 低电平，表示开启风扇
  12   1      }
  13          
  14          //
  15          void fan_ctl(void)
  16          {
  17   1          // 如果两路PWM都低于 10%， 控制脚 输出高电平
  18   1          if (pwm_handle_param.cur_pwm_0_duty_val < ((u16)MAX_PWM_DUTY * 10 / 100) &&
  19   1              pwm_handle_param.cur_pwm_1_duty_val < ((u16)MAX_PWM_DUTY * 10 / 100))
  20   1          {
  21   2              P12 = 1; // 高电平，表示关闭风扇
  22   2          }
  23   1          else
  24   1          {
  25   2              /* 如果有一路PWM大于10%占空比 */
  26   2              P12 = 0; // 低电平，表示开启风扇
  27   2          }
  28   1      }



              /**
               * @brief иҺ·еҸ– rf йҒҘжҺ§еҷЁжҢүй”®й”®еҖјпјҢдҫӣ key_driver и°ғз”Ё
               *          иҝҷйҮҢдёҚиғҪеҢәеҲҶйҒҘжҺ§еҷЁзұ»еһӢпјҢеҸӘиғҪиҺ·еҸ–йҒҘжҺ§еҷЁжҢүй”®
               *
               * @return u8
               */
              static u8 rf_key_get_key_id(void)
              {
                  static volatile u8 last_key = NO_KEY;
                  static volatile u8 cur_key = NO_KEY;
                  static volatile u16 timeout_cnt = 0;
              
                  // if (0 == flag_is_recved_rf_data &&
                  //     timeout_cnt == 0)
                  // {
                  //     return cur_key;
                  // }
              
                  if (flag_is_recved_rf_data)
                  {
                      flag_is_recved_rf_data = 0;
                      // timeout_cnt = (u32)35 * 10 / RF_KEY_SCAN_CIRCLE_TIMES; // еҒҮи®ҫдёҖеё§433ж•°жҚ®еҚ 35ms
                      timeout_cnt = (u32)64 * 4 / RF_KEY_SCAN_CIRCLE_TIMES; // е®һйҷ…жөӢиҜ•дёҖеё§ж•°жҚ®пјҢеҢ…жӢ¬её§й—ҙйҡ
             -”пјҢжңү64ms
                      // timeout_cnt = (u32)64 * 6 / RF_KEY_SCAN_CIRCLE_TIMES; // е®һйҷ…жөӢиҜ•дёҖеё§ж•°жҚ®пјҢеҢ…жӢ¬её§й—
             -ҙйҡ”пјҢжңү64ms
                      // timeout_cnt = (u32)64 * 10 / RF_KEY_SCAN_CIRCLE_TIMES; // е®һйҷ…жөӢиҜ•дёҖеё§ж•°жҚ®пјҢеҢ…жӢ¬её§й
             -—ҙйҡ”пјҢжңү64ms
              
                      if (((u8)(rf_data >> 16) != RF_KEY_ADDR_BYTE_1 ||
                           (u8)(rf_data >> 8) != RF_KEY_ADDR_BYTE_2))
                      {
                          if (last_key == NO_KEY)
                          {
                              // жҺҘж”¶еҲ°дәҶж•°жҚ®пјҢдҪҶжҳҜең°еқҖдёҚеҢ№й…ҚпјҢд№ӢеүҚд№ҹжІЎжңүжҺҘж”¶еҲ°ж•°жҚ®
                              cur_key = NO_KEY;
                              timeout_cnt = 0; // еҸ–ж¶Ҳи¶…ж—¶и®Ўж•°
                              // printf("rf addr err\n");
                          }
                          else
                          {
C51 COMPILER V9.60.7.0   RF_RECV                                                           07/15/2026 14:29:05 PAGE 3   

                              // жҺҘж”¶еҲ°дәҶж•°жҚ®пјҢдҪҶжҳҜең°еқҖдёҚеҢ№й…ҚпјҢдҪҶжҳҜд№ӢеүҚжңүжҺҘж”¶еҲ°жӯЈзЎ®зҡ„ж•°жҚ®
                              cur_key = last_key;
                              // printf("rf addr err , last_key valid\n");
                          }
                      }
                      else
                      {
                          /*
                              еҰӮжһңеҪ“еүҚжҺҘж”¶еҲ°зҡ„ең°еқҖжӯЈзЎ®
                          */
                          cur_key = (u8)(rf_data & 0xFF); // иҺ·еҸ–дҪҺ8дҪҚдҪңдёәй”®еҖј
                          last_key = cur_key;
                          // printf("rf_data 0x %lx\n", rf_data);
                      }
                  }
                  else
                  {
                      // жІЎжңүж”¶еҲ°ж–°ж•°жҚ®
              
                      if (timeout_cnt > 0)
                      {
                          timeout_cnt--;
                          cur_key = last_key;
                          // printf("timeout_cnt == %u\n", timeout_cnt);
                      }
                      else
                      {
                          // и¶…ж—¶д№ӢеҗҺ
                          cur_key = NO_KEY;
                          last_key = NO_KEY;
                          // printf("timeout\n");
                      }
                  }
              
                  // if (cur_key != NO_KEY)
                  // {
                  // printf("cur_key == %u\n", (u16)cur_key);
                  // }
              
                  return (u8)cur_key; // зӣҙжҺҘиҺ·еҸ–й”®еҖј
              }
              
              /**
               * @brief е°ҶжҢүй”®еҖје’Ң key_driver_scan еҫ—еҲ°зҡ„жҢүй”®дәӢд»¶иҪ¬жҚўжҲҗи§Ұж‘ёжҢүй”®зҡ„дәӢд»¶
               *
               * @param key_val жҢүй”®й”®еҖј
               * @param key_event еңЁ key_driver_scan еҫ—еҲ°зҡ„жҢүй”®дәӢд»¶ KEY_EVENT
               * @return u8 еңЁ rf_key_event_table дёӯжүҫеҲ°зҡ„еҜ№еә”зҡ„жҢүй”®дәӢд»¶пјҢеҰӮжһңжІЎжңүеҲҷиҝ”еӣһ RF_433_KEY_
             -EVENT_NONE
               */
              static u8 rf_key_get_event(const u8 key_val, const u8 key_event)
              {
                  volatile u8 ret_key_event = RF_433_KEY_EVENT_NONE;
                  u8 key_event_index = 0;
                  u8 i = 0;
              
                  // if (key_event != KEY_EVENT_NONE)
                  // {
                  //     printf("key_val %bu, key_event %bu\n", key_val, key_event);
                  // }
              
              #if 0
C51 COMPILER V9.60.7.0   RF_RECV                                                           07/15/2026 14:29:05 PAGE 4   

                  if (key_event == KEY_EVENT_CLICK)
                  {
                      key_event_index = 1;
                  }
                  else if (key_event == KEY_EVENT_LONG)
                  {
                      key_event_index = 2;
                  }
              #endif
                  if (key_event == KEY_EVENT_PRESS)
                  {
                      key_event_index = 1;
                  }
                  else
                  {
                      return RF_433_KEY_EVENT_NONE;
                  }
              
                  for (i = 0; i < ARRAY_SIZE(rf_key_event_table); i++)
                  {
                      // еҰӮжһңеҫҖ KEY_EVENT жһҡдёҫдёӯж·»еҠ дәҶж–°зҡ„жҢүй”®дәӢд»¶пјҢиҝҷйҮҢжҹҘиЎЁзҡ„ж–№жі•е°ұдјҡеӨұж•ҲпјҢ
             -йңҖиҰҒжүӢеҠЁдҝ®ж”№
                      if (key_val == rf_key_event_table[i][0])
                      {
                          ret_key_event = rf_key_event_table[i][key_event_index];
                          break;
                      }
                  }
              
                  return ret_key_event;
              }
              
              //  еҮҪж•°еҶ…йғЁдјҡеҒҡйҒҘжҺ§еҷЁзұ»еһӢеҢәеҲҶ
